{
    "name": "@saas/api",
    "version": "1.0.0",
    "scripts": {
        "dev": "pnpm env:load tsx watch src/http/server.ts",
        "env:load": "dotenv -e ../../.env --",
        "db:migrate": "pnpm env:load prisma migrate dev",
        "db:migrate-create-only": "pnpm env:load prisma migrate dev --create-only",
        "db:studio": "pnpm env:load prisma studio",
        "db:seed": "pnpm env:load prisma db seed",
        "db:reset": "pnpm env:load prisma migrate reset",
        "build": "tsup",
        "start": "node dist/http/server.js",
        "start:dev": "pnpm env:load node dist/http/server.js"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "dependencies": {
        "@casl/ability": "^6.7.3",
        "@fastify/cors": "^11.1.0",
        "@fastify/jwt": "^10.0.0",
        "@fastify/swagger": "^9.5.1",
        "@fastify/swagger-ui": "^5.2.3",
        "@prisma/client": "6.15.0",
        "@react-email/components": "^1.0.12",
        "@saas/auth": "workspace:*",
        "@saas/contracts": "workspace:*",
        "@saas/env": "workspace:*",
        "bcryptjs": "^3.0.2",
        "fastify": "^5.5.0",
        "fastify-plugin": "^5.0.1",
        "fastify-type-provider-zod": "^6.0.0",
        "immer": "^11.1.4",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-email": "^6.6.5",
        "resend": "^6.12.3",
        "zod": "^4.1.5"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.0.0",
        "@saas/eslint-config": "workspace:*",
        "@saas/prettier": "workspace:*",
        "@saas/tsconfig": "workspace:*",
        "@types/bcryptjs": "^3.0.0",
        "@types/node": "^22.15.3",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "dotenv-cli": "^10.0.0",
        "prisma": "^6.15.0",
        "tsup": "^8.5.0",
        "tsx": "^4.20.5"
    },
    "prettier": "@saas/prettier",
    "eslintConfig": {
        "extends": [
            "@saas/eslint-config/node"
        ]
    }
}
